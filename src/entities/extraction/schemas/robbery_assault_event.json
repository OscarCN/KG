{
    "RobberyAssaultEvent": {
        "meta": {
            "category": "event",
            "description": "An identifiable single robbery, assault, or property/person crime incident. Includes theft, mugging, carjacking, and general security events involving property or personal crime. Each incident is a specific occurrence distinguishable by its location and date — not a crime trend, security overview, or statistics report. Extracted from news articles and social media.",
            "example": {
                "event_type": "robbery",
                "event_subtype": "carjacking",
                "status": "past",
                "name": null,
                "description": "Armed carjacking reported on Blvd. Lopez Mateos, where two suspects stole a vehicle at gunpoint.",
                "tags": [
                    "carjacking",
                    "armed_robbery",
                    "blvd_lopez_mateos"
                ],
                "context": "Authorities report an increase in carjackings in the area over the past month.",
                "relevance": 1,
                "date_range": {
                    "date_range": {
                        "start": "2025-09-15T22:30:00",
                        "end": null
                    },
                    "timezone": null,
                    "mention": "la noche del lunes 15 de septiembre",
                    "precision_days": null
                },
                "location": {
                    "country": "Mexico",
                    "state": "Guanajuato",
                    "city": "Leon",
                    "neighborhood": null,
                    "zone": null,
                    "street": "Blvd. Lopez Mateos",
                    "number": null,
                    "place_name": null
                },
                "victim_count": {
                    "mention": "una persona",
                    "count": 1,
                    "confidence_range": null
                },
                "weapon": "firearm",
                "stolen_items": "vehiculo sedan color blanco",
                "suspect_description": "dos hombres encapuchados",
                "arrests_made": false
            }
        },
        "schema": {
            "event_type": {
                "type": "EnumStr",
                "importance": "essential",
                "required": true,
                "description": "Type of crime from the catalogue. Choose the single most specific category that matches.",
                "enum": [
                    "robbery",
                    "assault",
                    "kidnapping",
                    "security_event"
                ]
            },
            "event_subtype": {
                "type": "str",
                "importance": "secondary",
                "description": "More specific subtype, e.g. 'carjacking', 'home_burglary', 'mugging', 'armed_robbery', 'pickpocketing', 'express_kidnapping', 'ransom_kidnapping'."
            },
            "status": {
                "type": "EnumStr",
                "importance": "essential",
                "description": "Status of the incident as reported.",
                "enum": [
                    "past",
                    "ongoing",
                    "under_investigation"
                ]
            },
            "name": {
                "type": "str",
                "importance": "essential",
                "description": "Name or identifier for the incident, if any. Usually null for common crimes."
            },
            "description": {
                "type": "str",
                "importance": "essential",
                "description": "Brief free-text description of the incident."
            },
            "tags": {
                "type": "List[str]",
                "importance": "secondary",
                "description": "Keywords describing the incident."
            },
            "context": {
                "type": "str",
                "importance": "essential",
                "description": "Contextual information mentioned in the article."
            },
            "relevance": {
                "type": "EnumStr",
                "importance": "secondary",
                "description": "Relevance within the article: 1 = main topic, 2 = secondary, 3 = implicit.",
                "enum": [
                    "1",
                    "2",
                    "3"
                ]
            },
            "date_range": {
                "type": "DateRangeFromUnstructured",
                "importance": "essential",
                "description": "Date or date range when the incident occurred. Extract the start datetime and, if present, the end datetime."
            },
            "location": {
                "type": "Location",
                "importance": "essential",
                "description": "Location where the incident occurred."
            },
            "victim_count": {
                "type": "CountMention",
                "importance": "essential",
                "description": "Number of victims, with original text mention and parsed count."
            },
            "weapon": {
                "type": "str",
                "importance": "essential",
                "description": "Weapon used, if mentioned. E.g. 'firearm', 'knife', 'blunt_object'."
            },
            "stolen_items": {
                "type": "str",
                "importance": "secondary",
                "description": "Description of stolen items or property, if mentioned."
            },
            "suspect_description": {
                "type": "str",
                "importance": "secondary",
                "description": "Description of suspects, if mentioned."
            },
            "arrests_made": {
                "type": "bool",
                "importance": "secondary",
                "description": "Whether arrests were reported in connection with the incident."
            },
            "responding_authority": {
                "type": "str",
                "importance": "secondary",
                "description": "Law enforcement or authority that responded, if mentioned."
            }
        }
    }
}
